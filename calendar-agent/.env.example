# DeepSeek API key — get from https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Gmail credentials for sending reminders
# Use an App Password, NOT your regular Gmail password
# Enable 2FA then create one at: https://myaccount.google.com/apppasswords
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Default recipient for scheduled daily reminder emails
REMINDER_EMAIL=your_email@gmail.com

# Path to the .ics calendar file (relative or absolute)
CALENDAR_PATH=calendar.ics
